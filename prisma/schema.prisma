// ============================================================
// Grocery POS — Prisma Schema
// Database: PostgreSQL
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────
// User / Auth
// ──────────────────────────────────────
enum Role {
  OWNER
  MANAGER
  CASHIER
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String   // bcrypt hashed
  role      Role     @default(CASHIER)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bills Bill[] // Bills created by this user

  @@map("users")
}

// ──────────────────────────────────────
// Product Categories
// ──────────────────────────────────────
enum Category {
  VEGETABLES
  FRUITS
  GROCERIES
  PLANTS
  CLOTHES
}

// ──────────────────────────────────────
// Product
// ──────────────────────────────────────
model Product {
  id          String   @id @default(cuid())
  name        String
  barcode     String?  @unique     // Optional barcode
  category    Category
  price       Float                // Selling price
  costPrice   Float    @default(0) // Purchase cost (for profit calc)
  quantity    Int      @default(0) // Current stock
  unit        String   @default("pcs") // pcs, kg, litre, etc.
  minStock    Int      @default(5) // Low stock threshold
  expiryDate  DateTime?            // For perishables
  imageUrl    String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  billItems BillItem[]

  @@index([name])
  @@index([barcode])
  @@index([category])
  @@map("products")
}

// ──────────────────────────────────────
// Customer
// ──────────────────────────────────────
model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  email     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bills Bill[]

  @@index([phone])
  @@map("customers")
}

// ──────────────────────────────────────
// Bill / Invoice
// ──────────────────────────────────────
enum PaymentMethod {
  CASH
  CARD
  QR
}

model Bill {
  id            String        @id @default(cuid())
  billNumber    String        @unique // e.g., "BILL-20260329-001"
  subtotal      Float
  tax           Float         @default(0)
  discount      Float         @default(0)
  total         Float
  paymentMethod PaymentMethod @default(CASH)
  paidAmount    Float         @default(0)
  changeAmount  Float         @default(0)

  // Relations
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])
  userId     String
  user       User      @relation(fields: [userId], references: [id])

  items     BillItem[]
  createdAt DateTime   @default(now())

  @@index([createdAt])
  @@index([customerId])
  @@map("bills")
}

// ──────────────────────────────────────
// Bill Items (line items in each bill)
// ──────────────────────────────────────
model BillItem {
  id        String @id @default(cuid())
  quantity  Int
  price     Float  // Price at time of sale
  costPrice Float  @default(0)
  total     Float

  billId    String
  bill      Bill    @relation(fields: [billId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])

  @@map("bill_items")
}